{
  "headers": [
    {
      "source": "/social-preview-v3.jpg",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/social-preview-v3.png",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/es", "destination": "/" },
    { "source": "/es/", "destination": "/" },
    { "source": "/pt", "destination": "/" },
    { "source": "/pt/", "destination": "/" },
    { "source": "/en", "destination": "/" }
  ]
}
